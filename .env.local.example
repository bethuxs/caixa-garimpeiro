# ============================================================================
# CONFIGURAÇÃO LOCAL - Garimpeiro de Imóveis
# ============================================================================
# Copie este arquivo para .env.local e preench os valores

# ============================================================================
# CONFIGURAÇÃO DA VPS
# ============================================================================
VPS_URL=https://caixa.tecnofalls.com.br
VPS_TIMEOUT=30
# VPS_AUTH_KEY=sua_chave_secreta_aqui (opcional, para APIs protegidas)

# ============================================================================
# TELEGRAM (Opcional - para enviar alertas)
# ============================================================================
# TELEGRAM_TOKEN=seu_token_aqui
# TELEGRAM_CHAT_ID=seu_chat_id_aqui

# ============================================================================
# DEBUG
# ============================================================================
DEBUG=false
