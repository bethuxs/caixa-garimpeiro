# ============================================================================
# Variáveis de Ambiente - Garimpeiro de Imóveis
# ============================================================================
# IMPORTANTE: Copie este arquivo para .env e preench com seus valores reais
# NÃO COMMITE o arquivo .env com credenciais para o repositório!
#
# Instruções:
# 1. Crie um arquivo chamado ".env" na mesma pasta deste arquivo
# 2. Preencha com seus valores reais
# 3. Mantenha .env no .gitignore

# ============================================================================
# Configurações do Telegram Bot
# ============================================================================
# Para obter o TOKEN:
# 1. Converse com @BotFather no Telegram
# 2. Crie um novo bot (/newbot)
# 3. Copie o token fornecido
TELEGRAM_TOKEN=seu_token_aqui_do_botfather

# Para obter o CHAT_ID:
# 1. Converse com @userinfobot no Telegram
# 2. Obtenha seu ID de usuário
# Ou envie uma mensagem para o bot e capture o chat_id da resposta
TELEGRAM_CHAT_ID=seu_chat_id_pessoal

# ============================================================================
# Segurança da API Web
# ============================================================================
# Obrigatório para POST /api/sincronizar
SYNC_API_TOKEN=gere_um_token_longo_e_secreto

# Opcional: habilita CORS apenas para as origens listadas (separadas por vírgula)
# CORS_ORIGINS=https://caixa.tecnofalls.com.br,http://localhost:5000

# Opcional: usado pelo Flask para sessões/assinaturas
# SECRET_KEY=gere_outra_chave_longa_e_secreta

# ============================================================================
# Outras Configurações (Opcional)
# ============================================================================
# Timezone para logs e timestamps
TZ=America/Sao_Paulo

# Modo Debug (true/false)
DEBUG=false

# Intervalo de execução em horas (padrão: 1 hora)
EXECUTION_INTERVAL_HOURS=1
