# Variáveis de ambiente (NUNCA commitar credenciais!)
.env
.env.local
.env.*.local

# Banco de dados (gerado localmente)
*.db
*.db.backup.*
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Ambiente virtual
venv/
env/
ENV/
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
.classpath
*.sublime-project
*.sublime-workspace

# Playwright
.playwright/
test-results/
playwright-report/

# Cache
.pytest_cache/
.coverage
htmlcov/

# Arquivos temporários
tmp/
temp/
*.tmp
*.bak
*.backup

